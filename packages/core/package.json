{
  "name": "@vela/core",
  "version": "1.0.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/*": "./src/contracts/*.ts",
    "./runtime": "./src/runtime/index.ts",
    "./runtime/*": "./src/runtime/*.ts",
    "./validation": "./src/validation/index.ts",
    "./validation/*": "./src/validation/*.ts",
    "./utils": "./src/utils/index.ts",
    "./constants": "./src/constants/index.ts",
    "./*": "./src/*.ts"
  },
  "typesVersions": {
    "*": {
      "types": [
        "./src/types/index.ts"
      ],
      "types/*": [
        "./src/types/*.ts"
      ],
      "contracts": [
        "./src/contracts/index.ts"
      ],
      "contracts/*": [
        "./src/contracts/*.ts"
      ],
      "runtime": [
        "./src/runtime/index.ts"
      ],
      "runtime/*": [
        "./src/runtime/*.ts"
      ],
      "validation": [
        "./src/validation/index.ts"
      ],
      "validation/*": [
        "./src/validation/*.ts"
      ],
      "utils": [
        "./src/utils/index.ts"
      ],
      "constants": [
        "./src/constants/index.ts"
      ],
      "*": [
        "./src/*",
        "./src/*.ts"
      ]
    }
  },
  "dependencies": {
    "zod": "^4.3.5"
  }
}
