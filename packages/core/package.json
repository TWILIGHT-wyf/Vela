{
  "name": "@vela/core",
  "version": "1.0.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./utils": "./src/utils/index.ts",
    "./constants": "./src/constants/index.ts",
    "./*": "./src/*.ts"
  },
  "typesVersions": {
    "*": {
      "types": [
        "./src/types/index.ts"
      ],
      "types/*": [
        "./src/types/*.ts"
      ],
      "utils": [
        "./src/utils/index.ts"
      ],
      "constants": [
        "./src/constants/index.ts"
      ],
      "*": [
        "./src/*",
        "./src/*.ts"
      ]
    }
  },
  "dependencies": {
    "nanoid": "^5.1.6",
    "zod": "^4.3.5"
  }
}
