{
  "name": "@vela/generator",
  "version": "1.0.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./projectGenerator": "./src/projectGenerator.ts",
    "./*": "./src/*.ts"
  },
  "typesVersions": {
    "*": {
      "projectGenerator": [
        "./src/projectGenerator.ts"
      ],
      "*": [
        "./src/*.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/plugin-transform-typescript": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@vela/core": "workspace:*",
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.5",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
